<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>🌿 Grow Craft</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        :root {
            --bg: #0d1117;
            --dark: #161b22;
            --stone: #21262d;
            --border: #30363d;
            --green: #238636;
            --gold: #f0883e;
            --text: #c9d1d9;
            --text-bright: #f0f6fc;
            --muted: #8b949e;
            --dirt: #5d3a1a;
            --dirt-dark: #3d2914;
        }
        
        html, body { height: 100%; overflow: hidden; touch-action: manipulation; }
        body { font-family: 'Press Start 2P', monospace; font-size: 10px; background: var(--bg); color: var(--text); }
        
        .app { display: flex; flex-direction: column; height: 100%; height: 100dvh; }
        
        /* Header */
        .head { background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border-bottom: 3px solid #5d3a1a; padding: 10px 12px; display: flex; justify-content: space-between; align-items: center; }
        .logo { display: flex; align-items: center; gap: 8px; }
        .logo-icon { font-size: 22px; }
        .logo-text { font-size: 14px; color: #7fff7f; text-shadow: 2px 2px 0 #000; }
        .stats { display: flex; gap: 10px; align-items: center; }
        .stat { text-align: center; }
        .stat-v { font-size: 13px; color: var(--gold); text-shadow: 1px 1px 0 #000; }
        .stat-l { font-size: 7px; color: #8f8; }
        .speed { display: flex; gap: 4px; }
        .speed button { 
            width: 32px; height: 28px; font-size: 9px; 
            background: linear-gradient(180deg, #6b4423 0%, #5d3a1a 50%, #4a3520 100%);
            border: 2px solid #8b5a2b; border-top-color: #a0522d; border-bottom-color: #3d2914;
            color: #fff; text-shadow: 1px 1px 0 #000;
        }
        .speed button.on { background: linear-gradient(180deg, #4a8a4a 0%, #3a7a3a 50%, #2d5a2d 100%); border-color: #5aaa5a; border-top-color: #6aba6a; border-bottom-color: #2d5a2d; }
        
        /* Minecraft Tabs */
        .tabs { display: flex; flex-wrap: wrap; justify-content: center; background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); padding: 10px; gap: 8px; border-bottom: 3px solid #5d3a1a; }
        .tab { 
            padding: 12px 20px; font-size: 11px; 
            background: linear-gradient(180deg, #6b4423 0%, #5d3a1a 50%, #4a3520 100%);
            border: 3px solid #8b5a2b;
            border-top-color: #a0522d;
            border-left-color: #8b4513;
            border-right-color: #5d3a1a;
            border-bottom-color: #3d2914;
            color: #fff; text-shadow: 1px 1px 0 #000;
            min-width: 70px;
            text-align: center;
        }
        .tab.on { background: linear-gradient(180deg, #4a8a4a 0%, #3a7a3a 50%, #2d5a2d 100%); border-color: #5aaa5a; border-top-color: #6aba6a; border-bottom-color: #2d5a2d; color: #000; text-shadow: none; }
        
        /* Content */
        .content { flex: 1; overflow-y: auto; padding: 10px; padding-bottom: 70px; background: linear-gradient(180deg, #1a3d1a 0%, #0d1117 100%); }
        
        /* Grow Room */
        .room { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
        @media (max-width: 320px) { .room { grid-template-columns: repeat(2, 1fr); } }
        
        /* Square Pot */
        .pot { 
            background: linear-gradient(135deg, #5d3a1a 0%, #8b4513 50%, #5d3a1a 100%);
            border: 3px solid #3d2914;
            border-top-color: #8b5a2b;
            border-left-color: #a0522d;
            border-right-color: #3d2914;
            border-bottom-color: #2d1f0f;
            aspect-ratio: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
            border-radius: 0;
            box-shadow: inset -2px -2px 0 rgba(0,0,0,0.3), inset 2px 2px 0 rgba(255,255,255,0.1);
        }
        .pot:active { transform: translateY(2px); box-shadow: inset 2px 2px 0 rgba(0,0,0,0.3); }
        .pot.sel { border-color: var(--gold); box-shadow: 0 0 10px var(--gold), inset 0 0 4px rgba(240,136,62,0.3); }
        .pot.ready { border-color: var(--green); animation: pot-ready 1.5s infinite; }
        @keyframes pot-ready { 0%, 100% { box-shadow: 0 0 5px var(--green); } 50% { box-shadow: 0 0 15px var(--green); } }
        
        .pot-soil {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 70%; height: 70%;
            background: linear-gradient(135deg, #3d2914 0%, #5d3a1a 50%, #4a3520 100%);
            border-radius: 4px;
            border: 2px solid #2d1f0f;
        }
        
        /* Realistic Plant - CSS Art */
        .plant-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 80%;
            height: 80%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .plant-real {
            position: relative;
            image-rendering: pixelated;
        }
        
        /* Stage 0: Seed */
        .plant-0 {
            width: 12px;
            height: 12px;
            background: radial-gradient(ellipse 6px 8px at center, #8b6914 0%, #5d4a0f 100%);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            box-shadow: inset -2px -2px 0 rgba(0,0,0,0.3);
        }
        
        /* Stage 1: Sprout - two serrated leaves */
        .plant-1 {
            width: 40px;
            height: 30px;
            position: relative;
        }
        .plant-1::before, .plant-1::after {
            content: '';
            position: absolute;
            width: 18px;
            height: 25px;
            background: linear-gradient(135deg, #4a8 0%, #3a7a3a 50%, #2d6a2d 100%);
            clip-path: polygon(50% 0%, 60% 20%, 80% 15%, 70% 35%, 90% 30%, 80% 50%, 100% 50%, 85% 70%, 95% 85%, 75% 80%, 70% 100%, 50% 85%, 30% 100%, 25% 80%, 5% 85%, 15% 70%, 0% 50%, 20% 50%, 10% 30%, 30% 35%, 20% 15%, 40% 20%);
            box-shadow: inset -2px -2px 0 rgba(0,0,0,0.2), inset 1px 1px 0 rgba(255,255,255,0.1);
        }
        .plant-1::before { left: 2px; transform: rotate(-15deg); }
        .plant-1::after { right: 2px; transform: rotate(15deg); }
        
        /* Stage 2: Seedling - more leaves */
        .plant-2 {
            width: 50px;
            height: 45px;
            position: relative;
        }
        .plant-2::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 45px;
            height: 40px;
            background: radial-gradient(ellipse 22px 20px at center, #5a9a5a 0%, #4a8a4a 40%, #3a7a3a 100%);
            clip-path: polygon(50% 0%, 55% 15%, 70% 10%, 65% 25%, 80% 20%, 75% 35%, 90% 30%, 85% 45%, 100% 45%, 90% 60%, 100% 65%, 85% 75%, 95% 90%, 75% 85%, 70% 100%, 50% 90%, 30% 100%, 25% 85%, 5% 90%, 15% 75%, 0% 65%, 10% 60%, 0% 45%, 15% 45%, 10% 30%, 25% 35%, 20% 20%, 35% 25%, 30% 10%, 45% 15%);
            box-shadow: inset -3px -3px 0 rgba(0,0,0,0.2), inset 2px 2px 0 rgba(255,255,255,0.1);
        }
        
        /* Stage 3: Vegetative - bushy */
        .plant-3 {
            width: 60px;
            height: 55px;
            background: radial-gradient(ellipse 30px 28px at center, #6aba6a 0%, #4a9a4a 40%, #3a8a3a 80%, #2d7a2d 100%);
            border-radius: 45% 45% 50% 50%;
            box-shadow: inset -4px -4px 0 rgba(0,0,0,0.2), inset 3px 3px 0 rgba(255,255,255,0.08);
            position: relative;
        }
        .plant-3::before {
            content: '';
            position: absolute;
            top: 5px;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            height: 45px;
            background: radial-gradient(ellipse 25px 22px at center, #7aca7a 0%, #5aaa5a 60%, #4a9a4a 100%);
            border-radius: 45%;
            box-shadow: inset -2px -2px 0 rgba(0,0,0,0.15);
        }
        
        /* Stage 4: Pre-flower - pistils appear */
        .plant-4 {
            width: 70px;
            height: 65px;
            background: radial-gradient(ellipse 35px 32px at center, #6aba6a 0%, #4a9a4a 35%, #3a8a3a 70%, #2d7a2d 100%);
            border-radius: 45% 45% 50% 50%;
            box-shadow: inset -4px -4px 0 rgba(0,0,0,0.2), inset 3px 3px 0 rgba(255,255,255,0.08);
            position: relative;
        }
        .plant-4::before {
            content: '';
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 55px;
            background: radial-gradient(ellipse 30px 27px at center, #7aca7a 0%, #5aaa5a 50%, #4a9a4a 100%);
            border-radius: 45%;
        }
        .plant-4::after {
            content: '';
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            width: 30px;
            height: 25px;
            background: radial-gradient(ellipse 15px 12px at center, rgba(255,182,193,0.8) 0%, rgba(255,150,170,0.6) 100%);
            border-radius: 50%;
            box-shadow: 0 0 8px rgba(255,150,170,0.4);
        }
        
        /* Stage 5: Flowering - big buds */
        .plant-5 {
            width: 80px;
            height: 75px;
            background: radial-gradient(ellipse 40px 38px at center, #6aba6a 0%, #4a9a4a 25%, #3a8a3a 50%, #2d7a2d 100%);
            border-radius: 45% 45% 50% 50%;
            box-shadow: inset -5px -5px 0 rgba(0,0,0,0.2), inset 3px 3px 0 rgba(255,255,255,0.08);
            position: relative;
            animation: sway 3s ease-in-out infinite;
        }
        .plant-5::before {
            content: '';
            position: absolute;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            width: 65px;
            height: 60px;
            background: radial-gradient(ellipse 32px 30px at center, #7aca7a 0%, #5aaa5a 40%, #4a9a4a 100%);
            border-radius: 45%;
        }
        .plant-5::after {
            content: '';
            position: absolute;
            top: 15px;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            height: 45px;
            background: radial-gradient(ellipse 25px 22px at center, rgba(255,120,150,0.9) 0%, rgba(255,80,120,0.7) 60%, rgba(200,60,100,0.5) 100%);
            border-radius: 45%;
            box-shadow: 0 0 15px rgba(255,100,130,0.5);
        }
        @keyframes sway { 0%, 100% { transform: translate(-50%, -50%) rotate(-0.5deg); } 50% { transform: translate(-50%, -50%) rotate(0.5deg); } }
        
        /* Stage 6: Harvest - crystal-covered buds */
        .plant-6 {
            width: 90px;
            height: 85px;
            background: radial-gradient(ellipse 45px 42px at center, #5aba5a 0%, #4a9a4a 15%, #3a8a3a 30%, #2d7a2d 100%);
            border-radius: 45% 45% 50% 50%;
            box-shadow: 
                inset -6px -6px 0 rgba(0,0,0,0.25), 
                inset 4px 4px 0 rgba(255,255,255,0.06),
                0 0 20px rgba(255,255,255,0.2);
            position: relative;
            animation: harvest 4s ease-in-out infinite;
        }
        .plant-6::before {
            content: '';
            position: absolute;
            top: 15px;
            left: 50%;
            transform: translateX(-50%);
            width: 75px;
            height: 70px;
            background: radial-gradient(ellipse 38px 35px at center, #6aca6a 0%, #4aaa4a 30%, #3a9a3a 60%, #2d8a2d 100%);
            border-radius: 45%;
        }
        .plant-6::after {
            content: '';
            position: absolute;
            top: 18px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 55px;
            background: 
                radial-gradient(ellipse 12px 10px at 25% 30%, rgba(255,100,130,0.95) 0%, rgba(220,70,110,0.8) 100%),
                radial-gradient(ellipse 14px 11px at 75% 30%, rgba(255,100,130,0.95) 0%, rgba(220,70,110,0.8) 100%),
                radial-gradient(ellipse 15px 12px at 50% 50%, rgba(255,80,120,0.9) 0%, rgba(200,50,90,0.7) 100%),
                radial-gradient(ellipse 10px 8px at 20% 70%, rgba(255,100,130,0.9) 0%, rgba(220,70,110,0.7) 100%),
                radial-gradient(ellipse 11px 9px at 80% 70%, rgba(255,100,130,0.9) 0%, rgba(220,70,110,0.7) 100%);
            border-radius: 45%;
            box-shadow: 0 0 25px rgba(255,100,120,0.6);
        }
        /* Crystals */
        .plant-6 .crystals {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 65px;
            pointer-events: none;
        }
        .plant-6 .crystals::before,
        .plant-6 .crystals::after {
            content: '';
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(255,255,255,0.9);
            border-radius: 50%;
            box-shadow: 
                10px 5px 0 rgba(255,255,255,0.8),
                20px 2px 0 rgba(255,255,255,0.9),
                30px 8px 0 rgba(255,255,255,0.7),
                40px 3px 0 rgba(255,255,255,0.9),
                50px 10px 0 rgba(255,255,255,0.8),
                5px 15px 0 rgba(255,255,255,0.7),
                15px 20px 0 rgba(255,255,255,0.9),
                25px 18px 0 rgba(255,255,255,0.8),
                35px 22px 0 rgba(255,255,255,0.9),
                45px 17px 0 rgba(255,255,255,0.7),
                55px 25px 0 rgba(255,255,255,0.8),
                12px 30px 0 rgba(255,255,255,0.9),
                32px 28px 0 rgba(255,255,255,0.8),
                52px 35px 0 rgba(255,255,255,0.9),
                8px 40px 0 rgba(255,255,255,0.7),
                28px 45px 0 rgba(255,255,255,0.9),
                48px 42px 0 rgba(255,255,255,0.8);
            animation: crystals 2s ease-in-out infinite;
        }
        .plant-6 .crystals::after {
            animation-delay: 1s;
        }
        @keyframes harvest { 0%, 100% { transform: translate(-50%, -50%) scale(1); } 50% { transform: translate(-50%, -50%) scale(1.02); } }
        @keyframes crystals { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
        
        .pot-name { position: absolute; bottom: 3px; left: 0; right: 0; text-align: center; font-size: 7px; color: #fff; text-shadow: 1px 1px 0 #000; }
        .pot-progress { position: absolute; bottom: 14px; left: 0; right: 0; text-align: center; font-size: 8px; color: #7fff7f; text-shadow: 1px 1px 0 #000; }
        
        /* Minecraft Buttons */
        .actions { position: fixed; bottom: 0; left: 0; right: 0; background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border-top: 3px solid #5d3a1a; padding: 10px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; }
        .act { 
            background: linear-gradient(180deg, #6b4423 0%, #5d3a1a 50%, #4a3520 100%);
            border: 3px solid #8b5a2b;
            border-top-color: #a0522d;
            border-left-color: #8b4513;
            border-right-color: #5d3a1a;
            border-bottom-color: #3d2914;
            padding: 12px 4px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            color: #fff;
            text-shadow: 1px 1px 0 #000;
        }
        .act:active { transform: translateY(2px); }
        .act .i { font-size: 20px; }
        .act .t { font-size: 7px; }
        
        /* Modal */
        .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.9); display: none; align-items: center; justify-content: center; padding: 10px; z-index: 1000; }
        .modal.open { display: flex; }
        .box { background: linear-gradient(180deg, #2d1f0f 0%, #1a1a2e 100%); border: 3px solid #5d3a1a; width: 100%; max-width: 400px; max-height: 85vh; overflow-y: auto; }
        .mhead { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 3px solid #5d3a1a; }
        .mtit { font-size: 13px; color: #7fff7f; }
        .mclose { background: #8b0000; border: 2px solid #5a0000; color: #fff; font-size: 16px; width: 32px; height: 32px; }
        .mbody { padding: 12px; }
        
        /* Grid */
        .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
        .item { background: linear-gradient(180deg, #6b4423 0%, #5d3a1a 100%); border: 2px solid #8b5a2b; padding: 10px; text-align: center; }
        .item.off { opacity: 0.5; }
        .item .ii { font-size: 24px; }
        .item .in { font-size: 9px; margin: 4px 0 2px; color: var(--text-bright); }
        .item .id { font-size: 7px; color: var(--muted); }
        .item .ip { font-size: 9px; color: var(--gold); margin-top: 4px; }
        
        /* Cards */
        .card { background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border: 2px solid #5d3a1a; padding: 12px; margin-bottom: 10px; }
        .card-t { font-size: 12px; color: #7fff7f; margin-bottom: 10px; }
        .card-r { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #5d3a1a; font-size: 9px; }
        .card-p { font-size: 9px; color: #8f8; line-height: 1.6; margin-top: 8px; }
        
        /* Section Header */
        .section { display: flex; align-items: center; gap: 10px; margin: 14px 0 10px; padding: 10px; background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border: 2px solid #5d3a1a; }
        .section-icon { font-size: 22px; }
        .section-title { font-size: 12px; color: #7fff7f; }
        .section-desc { font-size: 8px; color: #8f8; margin-top: 3px; }
        
        /* Stats */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 10px; }
        .stat-box { background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border: 2px solid #5d3a1a; padding: 10px; text-align: center; }
        .stat-box .icon { font-size: 20px; }
        .stat-box .value { font-size: 14px; color: #7fff7f; margin: 5px 0; }
        .stat-box .label { font-size: 7px; color: #8f8; }
        
        /* Progress */
        .prog { height: 8px; background: #000; border-radius: 4px; overflow: hidden; border: 1px solid #333; }
        .prog-f { height: 100%; background: linear-gradient(90deg, #238636, #f0883e); }
        
        /* Toast */
        .toast { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: linear-gradient(180deg, #2d5a2d 0%, #1a3d1a 100%); border: 2px solid #3a5a3a; padding: 14px; text-align: center; z-index: 2000; display: none; }
        .toast.show { display: block; }
        .toast-t { font-size: 14px; color: #7fff7f; }
        .toast-x { font-size: 10px; margin-top: 5px; color: #8f8; }
        
        /* Tutorial */
        .tut { position: fixed; inset: 0; background: linear-gradient(180deg, #1a3d1a 0%, #0d1117 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; z-index: 3000; }
        .tut.h { display: none; }
        .tut h1 { font-size: 16px; color: #7fff7f; margin-bottom: 14px; }
        .tut-g { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-width: 320px; }
        .tut-b { background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border: 2px solid #5d3a1a; padding: 14px; }
        .tut-b h2 { font-size: 11px; color: #7fff7f; margin-bottom: 5px; }
        .tut-b p { font-size: 8px; color: #8f8; }
        .tut-s { background: linear-gradient(180deg, #4a8a4a 0%, #3a7a3a 50%, #2d5a2d 100%); border: 2px solid #2d5a2d; color: #000; font-size: 13px; padding: 14px 36px; margin-top: 18px; }
        
        /* Genes */
        .genes { display: flex; gap: 3px; margin-top: 5px; }
        .gene { width: 12px; height: 12px; border-radius: 2px; display: flex; align-items: center; justify-content: center; font-size: 7px; }
        .gene-t { background: #f85149; }
        .gene-c { background: #238636; }
        .gene-y { background: #f0883e; }
        .gene-s { background: #58a6ff; }
        .gene-r { background: #a371f7; }
        
        /* Equipment */
        .equip-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
        .equip-item { background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border: 2px solid #5d3a1a; padding: 12px; }
        .equip-item.owned { border-color: #238636; }
        .equip-item .ei { font-size: 24px; margin-bottom: 5px; }
        .equip-item .en { font-size: 10px; color: #7fff7f; }
        .equip-item .ed { font-size: 8px; color: #8f8; margin: 5px 0; }
        .equip-item .ec { font-size: 9px; color: var(--gold); }
        
        /* Lesson */
        .lesson { background: linear-gradient(180deg, #3d2914 0%, #2d1f0f 100%); border: 2px solid #5d3a1a; padding: 14px; margin-bottom: 10px; }
        .lesson h3 { font-size: 11px; color: #7fff7f; margin-bottom: 8px; }
        .lesson p { font-size: 9px; color: #c9d1d9; line-height: 1.6; margin-bottom: 8px; }
        .lesson .data { background: #1a1a2e; border: 1px solid #5d3a1a; padding: 10px; margin-top: 8px; }
        .lesson .data-row { display: flex; justify-content: space-between; font-size: 8px; padding: 3px 0; border-bottom: 1px solid #333; }
        .lesson .data-row:last-child { border-bottom: none; }
        .lesson .data-key { color: #8f8; }
        .lesson .data-val { color: #7fff7f; }
    </style>
</head>
<body>
    <div class="tut" id="tut">
        <h1>🌿 Grow Craft</h1>
        <div class="tut-g">
            <div class="tut-b"><h2>🌱</h2><p>Выращивай</p></div>
            <div class="tut-b"><h2>🔬</h2><p>Изучай науку</p></div>
            <div class="tut-b"><h2>🔧</h2><p>Покупай оборудование</p></div>
            <div class="tut-b"><h2>🧬</h2><p>Скрещивай сорта</p></div>
        </div>
        <button class="tut-s" id="start">▶ НАЧАТЬ</button>
    </div>

    <div class="app">
        <div class="head">
            <div class="logo"><span class="logo-icon">🌿</span><span class="logo-text">Grow Craft</span></div>
            <div class="stats">
                <div class="stat"><div class="stat-v" id="lvl">1</div><div class="stat-l">LVL</div></div>
                <div class="stat"><div class="stat-v" id="day">1</div><div class="stat-l">DAY</div></div>
                <div class="stat"><div class="stat-v" id="mny">500</div><div class="stat-l">💰</div></div>
                <div class="stat"><div class="stat-v" id="xp">0</div><div class="stat-l">XP</div></div>
                <div class="speed">
                    <button class="on" data-s="1">1x</button>
                    <button data-s="2">2x</button>
                    <button data-s="5">5x</button>
                    <button data-s="10">10x</button>
                </div>
            </div>
        </div>

        <div class="tabs" id="tabs">
            <button class="tab on" data-t="grow">🌱</button>
            <button class="tab" data-t="shop">🏪</button>
            <button class="tab" data-t="equip">🔧</button>
            <button class="tab" data-t="lab">🧪</button>
            <button class="tab" data-t="learn">📚</button>
            <button class="tab" data-t="stats">📊</button>
        </div>

        <div class="content" id="content"></div>

        <div class="actions">
            <button class="act" data-a="plant"><span class="i">🌱</span><span class="t">Посадить</span></button>
            <button class="act" data-a="water"><span class="i">💧</span><span class="t">Полить</span></button>
            <button class="act" data-a="nutrient"><span class="i">🧪</span><span class="t">Удобрения</span></button>
            <button class="act" data-a="harvest"><span class="i">✂️</span><span class="t">Собрать</span></button>
            <button class="act" data-a="save"><span class="i">💾</span><span class="t">Сейв</span></button>
        </div>
    </div>

    <!-- Modals -->
    <div class="modal" id="seedModal"><div class="box"><div class="mhead"><div class="mtit">🌱 Семена</div><button class="mclose" data-c="seedModal">✕</button></div><div class="mbody"><div class="grid" id="seedGrid"></div></div></div></div>
    <div class="modal" id="nutrModal"><div class="box"><div class="mhead"><div class="mtit">🧪 Удобрения</div><button class="mclose" data-c="nutrModal">✕</button></div><div class="mbody"><div class="grid" id="nutrGrid"></div></div></div></div>
    <div class="modal" id="infoModal"><div class="box"><div class="mhead"><div class="mtit" id="infoTit">Инфо</div><button class="mclose" data-c="infoModal">✕</button></div><div class="mbody" id="infoBody"></div></div></div>
    <div class="toast" id="toast"><div class="toast-t" id="tt"></div><div class="toast-x" id="tx"></div></div>

    <script>
        const tg = window.Telegram?.WebApp;
        if (tg) { tg.expand(); tg.ready(); }
        
        // Real cannabis science lessons
        const lessons = [
            {
                id: 'intro', title: '🌱 Введение в каннабис', unlocked: true,
                content: [
                    { title: 'Биология растения', text: 'Cannabis sativa и Cannabis indica — два основных вида. Сатива даёт энергию, индика расслабляет. Гибриды сочетают эффекты.' },
                    { title: 'Фотопериодизм', text: 'Каннабис — короткодневное растение. Цветение начинается при 12 часах света. Вегетация требует 18-24 часа света.' },
                    { title: 'Химия', text: 'THC (тетрагидроканнабинол) — психоактивное вещество. CBD (каннабидиол) — медицинский эффект. Терпены дают аромат.' }
                ]
            },
            {
                id: 'germ', title: '🌰 Проращивание', unlocked: true,
                content: [
                    { title: 'Условия', text: 'Температура: 20-26°C (68-79°F). Влажность: 70-90%. pH воды: 6.0-6.5. Тёмное место.' },
                    { title: 'Методы', text: 'Метод бумажного полотенца: семя между влажными слоями, в тёмное место. Прямо в субстрат: на глубину 1-2 см.' },
                    { title: 'Признаки успеха', text: 'Корешок 2-5 мм за 2-7 дней. Не трогай корень! Сажай корешком вниз.' }
                ]
            },
            {
                id: 'light', title: '💡 Освещение', unlocked: true,
                content: [
                    { title: 'Спектр света', text: 'Синий (400-500nm) — вегетация, компактность. Красный (600-700nm) — цветение, урожай. Полный спектр — оптимально.' },
                    { title: 'PPFD и DLI', text: 'PPFD: 600-1000 µmol/m²/s для вегетации, 1000-1500 для цветения. DLI: 35-45 моль/день оптимально.' },
                    { title: 'Типы ламп', text: 'LED — эффективность 2.5-3.0 µmol/J. HPS — классика, но греет. CMH — естественный спектр.' }
                ]
            },
            {
                id: 'water', title: '💧 Полив и pH', unlocked: true,
                content: [
                    { title: 'pH критичен', text: 'Грунт: pH 6.0-7.0. Гидропоника: pH 5.5-6.5. Выше 7.0 = блокировка питательных веществ.' },
                    { title: 'Lift Test', text: 'Подними горшок. Лёгкий = пора поливать. Тяжёлый = подожди. Переувлажнение = корневая гниль.' },
                    { title: 'EC/PPM', text: 'Вегетация: EC 1.0-1.6. Цветение: EC 1.6-2.4. Высокий EC = сожжённые корни.' }
                ]
            },
            {
                id: 'npk', title: '🧪 NPK и питание', unlocked: true,
                content: [
                    { title: 'Макроэлементы', text: 'N (азот) — листья, вегетация. P (фосфор) — корни, цветы. K (калий) — иммунитет, транспорт.' },
                    { title: 'Микроэлементы', text: 'Mg (магний) — хлорофилл. Ca (кальций) — клеточные стенки. Fe (железо) — ферменты. S (сера) — аромат.' },
                    { title: 'Дефициты', text: 'Жёлтые нижние листья = N дефицит. Фиолетовые стебли = P дефицит. Коричневые края = K дефицит.' }
                ]
            },
            {
                id: 'training', title: '🌿 Тренировки (LST/HST)', unlocked: false,
                content: [
                    { title: 'LST (Low Stress Training)', text: 'Гибка ветвей без повреждений. Создаёт ровную крону. Увеличивает урожай на 20-40%.' },
                    { title: 'Topping', text: 'Срез верхушки над 5-6 узлом. Создаёт 2 колы вместо 1. Делай за 2 недели до цветения.' },
                    { title: 'FIM', text: 'Срез 75% верхушки. 4 новые колы. Риск ошибки выше, чем topping.' }
                ]
            },
            {
                id: 'flower', title: '🌸 Цветение', unlocked: false,
                content: [
                    { title: 'Стадии цветения', text: 'Неделя 1-3: Растягивание. Неделя 4-5: Формирование бутонов. Неделя 6-8: Набухание. Неделя 9+: Созревание.' },
                    { title: 'Трихомы', text: 'Прозрачные = не готово. Мутные = пик THC. Янтарные = седативный эффект. 70% мутных = оптимально.' },
                    { title: 'Время света', text: '12/12 — классика. 11/13 — для сативы. 10/14 — для автоцветов в конце.' }
                ]
            },
            {
                id: 'harvest', title: '✂️ Сбор и сушка', unlocked: false,
                content: [
                    { title: 'Срез', text: 'Срезай в темноте. Оставляй 14 дней промывки без удобрений. Тримминг влажий или сухой.' },
                    { title: 'Сушка', text: 'Температура: 15-21°C (60-70°F). Влажность: 45-55%. Тёмное место. Вентиляция. 7-14 дней.' },
                    { title: 'Curing', text: 'Стеклянные банки. Burping: открывай 1-2 раза/день первую неделю. 2-8 недель для качества.' }
                ]
            },
            {
                id: 'genetics', title: '🧬 Генетика', unlocked: false,
                content: [
                    { title: 'Менделевское наследование', text: 'Каждый ген — пара аллелей. Доминантные (T, Y) = сильнее. Рецессивные (t, y) = слабее.' },
                    { title: '5 ключевых генов', text: 'T = THC потенциал. C = CBD потенциал. Y = урожайность. S = скорость роста. R = устойчивость.' },
                    { title: 'Скрещивание', text: 'Гомозиготные (TT) × гетерозиготные (Tt) = 50% TT, 50% Tt. Скрещивай лучших для лучших потомков.' }
                ]
            },
            {
                id: 'pests', title: '🐛 Вредители и болезни', unlocked: false,
                content: [
                    { title: 'Паутинный клещ', text: 'Микроскопический, оставляет паутину. Neem oil — профилактика. Predatory mites — биоконтроль.' },
                    { title: 'Мучнистая роса', text: 'Белый налёт на листьях. Причина: высокая влажность + низкая вентиляция. Sulphur burner — лечение.' },
                    { title: 'Корневая гниль', text: 'Коричневые слизкие корни. Причина: переувлажнение. Hydrogen peroxide 3% — временная помощь.' }
                ]
            }
        ];
        
        const strains = [
            { id: 'nl', name: 'Northern Lights', type: 'Indica', icon: '🌿', thc: 18, yld: 400, price: 50, speed: 1.0 },
            { id: 'ww', name: 'White Widow', type: 'Hybrid', icon: '🍃', thc: 20, yld: 450, price: 60, speed: 1.1 },
            { id: 'bd', name: 'Blue Dream', type: 'Sativa', icon: '💠', thc: 21, yld: 500, price: 70, speed: 1.2 },
            { id: 'og', name: 'OG Kush', type: 'Hybrid', icon: '🌲', thc: 23, yld: 480, price: 120, speed: 1.0 },
            { id: 'gl', name: 'Gelato', type: 'Hybrid', icon: '🍦', thc: 27, yld: 400, price: 150, speed: 0.9 },
            { id: 'gg', name: 'Gorilla Glue', type: 'Hybrid', icon: '🦍', thc: 30, yld: 550, price: 180, speed: 0.85 },
            { id: 'sk', name: 'Skunk #1', type: 'Hybrid', icon: '🦨', thc: 19, yld: 420, price: 40, speed: 1.3 },
            { id: 'cm', name: 'Critical Mass', type: 'Indica', icon: '⚖️', thc: 20, yld: 600, price: 45, speed: 1.1 },
            { id: 'ak', name: 'AK-47', type: 'Hybrid', icon: '🔫', thc: 22, yld: 450, price: 55, speed: 1.2 },
            { id: 'am', name: 'Amnesia Haze', type: 'Sativa', icon: '🌀', thc: 25, yld: 480, price: 90, speed: 0.8 },
            { id: 'pk', name: 'Purple Kush', type: 'Indica', icon: '💜', thc: 24, yld: 380, price: 100, speed: 0.9 },
            { id: 'sd', name: 'Sour Diesel', type: 'Sativa', icon: '⛽', thc: 26, yld: 520, price: 85, speed: 1.0 }
        ];
        
        const nutrients = [
            { id: 'grow', name: 'Grow Mix', icon: '🟢', desc: 'NPK 3-1-2', price: 25, inv: 0 },
            { id: 'bloom', name: 'Bloom Mix', icon: '🟣', desc: 'NPK 1-3-2', price: 30, inv: 0 },
            { id: 'calmag', name: 'Cal-Mag', icon: '💊', desc: 'Ca+Mg', price: 35, inv: 0 },
            { id: 'pk', name: 'PK Boost', icon: '⚡', desc: 'P+K', price: 40, inv: 0 },
            { id: 'root', name: 'Root Boost', icon: '🌿', desc: 'Корни', price: 20, inv: 0 },
            { id: 'enz', name: 'Enzymes', icon: '🔬', desc: 'Очистка', price: 50, inv: 0 }
        ];
        
        const equipment = [
            { id: 'lamp100', name: 'LED 100W', icon: '💡', desc: 'Базовый', price: 100, bonus: 1.1, owned: false },
            { id: 'lamp300', name: 'LED 300W', icon: '💡', desc: 'Средний', price: 300, bonus: 1.25, owned: false },
            { id: 'lamp600', name: 'LED 600W', icon: '💡', desc: 'Мощный', price: 600, bonus: 1.4, owned: false },
            { id: 'fan', name: 'Вентилятор', icon: '🌀', desc: 'Циркуляция', price: 50, bonus: 1.05, owned: false },
            { id: 'filter', name: 'Угольный фильтр', icon: '🔲', desc: 'Запах', price: 80, bonus: 1.0, owned: false },
            { id: 'hygro', name: 'Гигрометр', icon: '📊', desc: 'Климат', price: 30, bonus: 1.08, owned: false },
            { id: 'timer', name: 'Таймер', icon: '⏱️', desc: 'Авто-свет', price: 25, bonus: 1.05, owned: false },
            { id: 'ph', name: 'pH-метр', icon: '⚗️', desc: 'Точный pH', price: 40, bonus: 1.1, owned: false },
            { id: 'pot5', name: 'Горшок 5L', icon: '🪴', desc: '+1 слот', price: 50, bonus: 0, owned: false },
            { id: 'pot10', name: 'Горшок 10L', icon: '🪴', desc: '+2 слота', price: 100, bonus: 0, owned: false },
            { id: 'tent', name: 'Гроубокс 1x1', icon: '🏠', desc: '+4 слота', price: 200, bonus: 1.2, owned: false },
            { id: 'tent2', name: 'Гроубокс 2x2', icon: '🏠', desc: '+8 слотов', price: 500, bonus: 1.35, owned: false }
        ];
        
        const labItems = [
            { id: 'microscope', name: 'Микроскоп', icon: '🔬', desc: 'Трихомы', price: 150, owned: false },
            { id: 'cloner', name: 'Клон-машина', icon: '🌱', desc: 'Клоны', price: 200, owned: false },
            { id: 'dryer', name: 'Сушилка', icon: '💨', desc: 'Качество', price: 120, owned: false },
            { id: 'trimmer', name: 'Триммер', icon: '✂️', desc: 'Скорость', price: 180, owned: false },
            { id: 'extractor', name: 'Экстрактор', icon: '⚗️', desc: 'Масло', price: 300, owned: false }
        ];
        
        let S = {
            day: 1, time: 6, speed: 1, money: 500, xp: 0, level: 1,
            plants: [], slots: 6, selected: null,
            inv: { grow: 5, bloom: 3, calmag: 2, pk: 1, root: 0, enz: 0 },
            equipment: [],
            lab: [],
            research: [
                { id: 'gen', name: 'Генетика', desc: 'Гены', cost: 150, done: false },
                { id: 'breed', name: 'Скрещивание', desc: 'Разблок', cost: 200, done: false },
                { id: 'yield', name: 'Урожайность', desc: '+30%', cost: 450, done: false },
                { id: 'speed', name: 'Скорость', desc: '+20%', cost: 300, done: false },
                { id: 'quality', name: 'Качество', desc: '+THC', cost: 500, done: false },
                { id: 'clone', name: 'Клонирование', desc: 'Клоны', cost: 400, done: false }
            ],
            stats: { harvests: 0, planted: 0, bred: 0 },
            breed: [null, null]
        };
        
        let loop = null;
        
        function load() { const s = localStorage.getItem('gc8'); if (s) S = {...S, ...JSON.parse(s)}; }
        function save() { localStorage.setItem('gc8', JSON.stringify(S)); }
        
        function toast(t, x) {
            document.getElementById('tt').textContent = t;
            document.getElementById('tx').textContent = x;
            document.getElementById('toast').classList.add('show');
            setTimeout(() => document.getElementById('toast').classList.remove('show'), 1500);
        }
        
        function tick() {
            S.time += 0.5 * S.speed;
            if (S.time >= 24) { S.time = 0; S.day++; }
            
            const equipBonus = S.equipment.reduce((sum, id) => { const e = equipment.find(x => x.id === id); return sum + (e?.bonus || 1); }, 0) || 1;
            const hasLab = S.lab.length > 0 ? 1.1 : 1;
            
            S.plants.forEach(p => {
                p.progress += (1.2 * S.speed * 0.05) * equipBonus * hasLab * p.strain.speed;
                p.water -= 0.2 * S.speed;
                if (p.water < 30) p.health -= 0.1 * S.speed;
                if (p.water > 80) p.health -= 0.05 * S.speed;
                p.health = Math.max(0, Math.min(100, p.health));
                p.stage = p.progress < 5 ? 0 : p.progress < 10 ? 1 : p.progress < 20 ? 2 : p.progress < 40 ? 3 : p.progress < 60 ? 4 : p.progress < 90 ? 5 : 6;
            });
            
            const need = S.level * 100;
            if (S.xp >= need) { S.xp -= need; S.level++; toast('🎉', 'Уровень ' + S.level); }
            update();
        }
        
        function update() {
            document.getElementById('lvl').textContent = S.level;
            document.getElementById('day').textContent = S.day;
            document.getElementById('mny').textContent = S.money;
            document.getElementById('xp').textContent = S.xp;
        }
        
        function render(tab) {
            const c = document.getElementById('content');
            
            if (tab === 'grow') {
                let html = '<div class="room">';
                for (let i = 0; i < S.slots; i++) {
                    const p = S.plants.find(x => x.slot === i);
                    const sel = S.selected === i ? 'sel' : '';
                    const ready = p && p.stage >= 6 ? 'ready' : '';
                    
                    if (p) {
                        html += `<div class="pot ${sel} ${ready}" data-slot="${i}">
                            <div class="pot-soil"></div>
                            <div class="plant-container">
                                <div class="plant-real plant-${p.stage}">${p.stage >= 6 ? '<div class="crystals"></div>' : ''}</div>
                            </div>
                            <div class="pot-progress">${Math.floor(p.progress)}%</div>
                            <div class="pot-name">${p.strain.name.slice(0, 8)}</div>
                        </div>`;
                    } else {
                        html += `<div class="pot ${sel}" data-slot="${i}">
                            <div class="pot-soil"></div>
                            <div class="pot-name">ПУСТО</div>
                        </div>`;
                    }
                }
                html += '</div>';
                c.innerHTML = html;
            }
            else if (tab === 'shop') {
                c.innerHTML = `
                    <div class="section"><span class="section-icon">🌱</span><div><div class="section-title">Семена</div><div class="section-desc">12 сортов</div></div></div>
                    <div class="grid" id="seedGrid"></div>
                    <div class="section"><span class="section-icon">🧪</span><div><div class="section-title">Удобрения</div><div class="section-desc">NPK формулы</div></div></div>
                    <div class="grid" id="nutrGrid"></div>`;
                
                document.getElementById('seedGrid').innerHTML = strains.map(s => 
                    `<div class="item ${S.money < s.price ? 'off' : ''}" data-seed="${s.id}"><div class="ii">${s.icon}</div><div class="in">${s.name.slice(0, 10)}</div><div class="id">${s.type} | THC ${s.thc}%</div><div class="ip">💰${s.price}</div></div>`
                ).join('');
                
                document.getElementById('nutrGrid').innerHTML = nutrients.map(n => 
                    `<div class="item ${S.money < n.price ? 'off' : ''}" data-nut="${n.id}"><div class="ii">${n.icon}</div><div class="in">${n.name}</div><div class="id">${n.desc}</div><div class="ip">💰${n.price} | x${S.inv[n.id] || 0}</div></div>`
                ).join('');
            }
            else if (tab === 'equip') {
                c.innerHTML = '<div class="section"><span class="section-icon">💡</span><div><div class="section-title">Освещение</div><div class="section-desc">PPFD и спектр</div></div></div>';
                c.innerHTML += equipment.filter(e => e.id.includes('lamp')).map(e => 
                    `<div class="equip-item ${S.equipment.includes(e.id) ? 'owned' : ''}" data-equip="${e.id}">
                        <div class="ei">${e.icon}</div>
                        <div class="en">${e.name}</div>
                        <div class="ed">${e.desc} | +${Math.round((e.bonus - 1) * 100)}%</div>
                        <div class="ec">${S.equipment.includes(e.id) ? '✅ Установлено' : '💰 ' + e.price}</div>
                    </div>`
                ).join('');
                
                c.innerHTML += '<div class="section"><span class="section-icon">🌀</span><div><div class="section-title">Климат</div><div class="section-desc">Вентиляция и контроль</div></div></div>';
                c.innerHTML += equipment.filter(e => ['fan', 'filter', 'hygro', 'timer', 'ph'].includes(e.id)).map(e => 
                    `<div class="equip-item ${S.equipment.includes(e.id) ? 'owned' : ''}" data-equip="${e.id}">
                        <div class="ei">${e.icon}</div>
                        <div class="en">${e.name}</div>
                        <div class="ed">${e.desc} ${e.bonus > 1 ? '| +' + Math.round((e.bonus - 1) * 100) + '%' : ''}</div>
                        <div class="ec">${S.equipment.includes(e.id) ? '✅ Установлено' : '💰 ' + e.price}</div>
                    </div>`
                ).join('');
                
                c.innerHTML += '<div class="section"><span class="section-icon">🏠</span><div><div class="section-title">Гроубоксы</div><div class="section-desc">Больше слотов</div></div></div>';
                c.innerHTML += equipment.filter(e => ['pot5', 'pot10', 'tent', 'tent2'].includes(e.id)).map(e => 
                    `<div class="equip-item ${S.equipment.includes(e.id) ? 'owned' : ''}" data-equip="${e.id}">
                        <div class="ei">${e.icon}</div>
                        <div class="en">${e.name}</div>
                        <div class="ed">${e.desc}</div>
                        <div class="ec">${S.equipment.includes(e.id) ? '✅ Куплено' : '💰 ' + e.price}</div>
                    </div>`
                ).join('');
            }
            else if (tab === 'lab') {
                c.innerHTML = '<div class="section"><span class="section-icon">🔬</span><div><div class="section-title">Лаборатория</div><div class="section-desc">Продвинутое оборудование</div></div></div>';
                c.innerHTML += labItems.map(l => 
                    `<div class="equip-item ${S.lab.includes(l.id) ? 'owned' : ''}" data-lab="${l.id}">
                        <div class="ei">${l.icon}</div>
                        <div class="en">${l.name}</div>
                        <div class="ed">${l.desc}</div>
                        <div class="ec">${S.lab.includes(l.id) ? '✅ Куплено' : '💰 ' + l.price}</div>
                    </div>`
                ).join('');
                
                c.innerHTML += '<div class="section" style="margin-top:16px"><span class="section-icon">🧬</span><div><div class="section-title">Генетика</div><div class="section-desc">Менделевское наследование</div></div></div>';
                c.innerHTML += `<div class="card">
                    <div class="card-r"><span>Ген T</span><span>THC потенциал</span></div>
                    <div class="card-r"><span>Ген C</span><span>CBD потенциал</span></div>
                    <div class="card-r"><span>Ген Y</span><span>Урожайность</span></div>
                    <div class="card-r"><span>Ген S</span><span>Скорость роста</span></div>
                    <div class="card-r"><span>Ген R</span><span>Устойчивость</span></div>
                </div>`;
            }
            else if (tab === 'learn') {
                c.innerHTML = '<div class="section"><span class="section-icon">📚</span><div><div class="section-title">Академия Гровинга</div><div class="section-desc">Научные данные</div></div></div>';
                lessons.forEach((l, i) => {
                    const unlocked = l.unlocked || (l.id === 'training' && S.stats.harvests >= 1) || 
                                     (l.id === 'flower' && S.stats.harvests >= 2) || 
                                     (l.id === 'harvest' && S.stats.harvests >= 5) ||
                                     (l.id === 'genetics' && S.research[0].done) ||
                                     (l.id === 'pests' && S.stats.planted >= 10);
                    c.innerHTML += `<div class="lesson" style="opacity:${unlocked ? 1 : 0.5}" data-lesson="${l.id}">
                        <h3>${l.title} ${unlocked ? '▶' : '🔒'}</h3>
                    </div>`;
                });
                c.innerHTML += '<div class="card" id="lessonContent" style="display:none;margin-top:10px"></div>';
            }
            else if (tab === 'stats') {
                const need = S.level * 100;
                c.innerHTML = `<div class="card"><div class="card-t">📊 Прогресс</div><div style="margin-bottom:10px;font-size:9px">Уровень ${S.level} • ${S.xp}/${need} XP</div><div class="prog"><div class="prog-f" style="width:${(S.xp/need)*100}%"></div></div></div>
                <div class="card"><div class="card-t">📈 Статистика</div>
                    <div class="card-r"><span>🌱 Посажено</span><span>${S.stats.planted}</span></div>
                    <div class="card-r"><span>✂️ Урожаев</span><span>${S.stats.harvests}</span></div>
                    <div class="card-r"><span>🧬 Скрещиваний</span><span>${S.stats.bred}</span></div>
                    <div class="card-r"><span>🔧 Оборудования</span><span>${S.equipment.length}</span></div>
                    <div class="card-r"><span>🔬 Исследований</span><span>${S.research.filter(r => r.done).length}</span></div>
                    <div class="card-r"><span>💰 Баланс</span><span>$${S.money}</span></div>
                </div>`;
            }
        }
        
        function showLesson(id) {
            const l = lessons.find(x => x.id === id);
            if (!l) return;
            
            let html = `<h3 style="font-size:12px;color:#7fff7f;margin-bottom:10px">${l.title}</h3>`;
            l.content.forEach(c => {
                html += `<div style="margin-bottom:12px">
                    <div style="font-size:10px;color:#f0883e;margin-bottom:5px">${c.title}</div>
                    <div style="font-size:9px;color:#c9d1d9;line-height:1.6">${c.text}</div>
                </div>`;
            });
            document.getElementById('lessonContent').innerHTML = html;
            document.getElementById('lessonContent').style.display = 'block';
            S.xp += 15;
            toast('📚', '+15 XP');
            save();
        }
        
        function plantSeed(id) {
            if (S.selected === null) { toast('❌', 'Выбери слот'); return; }
            if (S.plants.find(p => p.slot === S.selected)) { toast('❌', 'Слот занят'); return; }
            const strain = strains.find(s => s.id === id);
            if (S.money < strain.price) { toast('❌', 'Не хватает'); return; }
            S.money -= strain.price;
            S.plants.push({
                slot: S.selected, strain: strain,
                genes: { t: (Math.random() > 0.5 ? 'T' : 't') + (Math.random() > 0.5 ? 'T' : 't'), c: (Math.random() > 0.7 ? 'C' : 'c') + (Math.random() > 0.7 ? 'C' : 'c'), y: (Math.random() > 0.5 ? 'Y' : 'y') + (Math.random() > 0.5 ? 'Y' : 'y'), s: (Math.random() > 0.5 ? 'S' : 's') + (Math.random() > 0.5 ? 'S' : 's'), r: (Math.random() > 0.5 ? 'R' : 'r') + (Math.random() > 0.5 ? 'R' : 'r') },
                progress: 0, stage: 0, health: 100, water: 70
            });
            S.stats.planted++;
            S.xp += 5;
            document.getElementById('seedModal').classList.remove('open');
            render('grow');
            toast('🌱', strain.name);
            save();
        }
        
        function buyNutrient(id) {
            const n = nutrients.find(x => x.id === id);
            if (S.money < n.price) { toast('❌', 'Не хватает'); return; }
            S.money -= n.price;
            S.inv[id] = (S.inv[id] || 0) + 1;
            toast('🧪', n.name + ' куплено');
            save();
        }
        
        function buyEquipment(id) {
            if (S.equipment.includes(id)) { toast('❌', 'Уже есть'); return; }
            const e = equipment.find(x => x.id === id);
            if (S.money < e.price) { toast('❌', 'Не хватает'); return; }
            
            if (id === 'pot5') { S.slots += 1; S.money -= e.price; S.equipment.push(id); toast('🪴', '+1 слот'); }
            else if (id === 'pot10') { S.slots += 2; S.money -= e.price; S.equipment.push(id); toast('🪴', '+2 слота'); }
            else if (id === 'tent') { S.slots += 4; S.money -= e.price; S.equipment.push(id); toast('🏠', '+4 слота'); }
            else if (id === 'tent2') { S.slots += 8; S.money -= e.price; S.equipment.push(id); toast('🏠', '+8 слотов'); }
            else { S.money -= e.price; S.equipment.push(id); toast('🔧', e.name); }
            
            save();
            render('equip');
        }
        
        function buyLab(id) {
            if (S.lab.includes(id)) { toast('❌', 'Уже есть'); return; }
            const l = labItems.find(x => x.id === id);
            if (S.money < l.price) { toast('❌', 'Не хватает'); return; }
            S.money -= l.price;
            S.lab.push(id);
            toast('🔬', l.name);
            save();
            render('lab');
        }
        
        function harvest(p) {
            const yld = Math.floor(p.strain.yld * (p.genes.y.includes('Y') ? 1.3 : 0.85) * (p.health / 100));
            S.money += yld * 2;
            S.xp += yld;
            S.stats.harvests++;
            S.plants = S.plants.filter(x => x.slot !== p.slot);
            S.selected = null;
            document.getElementById('infoModal').classList.remove('open');
            toast('✂️', `${yld}г • +$${yld * 2}`);
            render('grow');
            save();
        }
        
        function showInfo(p) {
            document.getElementById('infoTit').textContent = p.strain.name;
            const yld = Math.floor(p.strain.yld * (p.genes.y.includes('Y') ? 1.3 : 0.85) * (p.health / 100));
            const daysLeft = Math.max(0, Math.ceil((100 - p.progress) / (10 * S.speed)));
            
            let html = `<div class="stats-grid">
                <div class="stat-box"><div class="icon">📊</div><div class="value">${Math.floor(p.progress)}%</div><div class="label">Прогресс</div></div>
                <div class="stat-box"><div class="icon">⚖️</div><div class="value">${yld}г</div><div class="label">Урожай</div></div>
                <div class="stat-box"><div class="icon">⏱️</div><div class="value">${daysLeft}д</div><div class="label">Осталось</div></div>
                <div class="stat-box"><div class="icon">💰</div><div class="value">$${yld * 2}</div><div class="label">Прибыль</div></div>
            </div>
            <div class="card" style="margin-top:10px">
                <div class="card-r"><span>❤️ Здоровье</span><span>${Math.floor(p.health)}%</span></div>
                <div class="prog" style="margin-top:5px"><div class="prog-f" style="width:${p.health}%"></div></div>
                <div class="card-r" style="margin-top:8px"><span>💧 Вода</span><span>${Math.floor(p.water)}%</span></div>
                <div class="prog" style="margin-top:5px"><div class="prog-f" style="width:${p.water}%"></div></div>
            </div>`;
            
            if (S.research[0].done) {
                html += `<div class="card" style="margin-top:10px"><div style="font-size:10px;color:#7fff7f;margin-bottom:8px">🧬 Гены</div>
                <div class="genes">${['t', 'c', 'y', 's', 'r'].map(g => `<div class="gene gene-${g}">${p.genes[g].includes(g.toUpperCase()) ? '★' : '○'}</div>`).join('')}</div></div>`;
            }
            
            if (p.stage >= 6) {
                html += `<button class="tut-s" style="width:100%;margin-top:10px" id="harvestBtn">✂️ Собрать урожай</button>`;
            } else {
                html += `<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px">
                    <button class="tut-s" id="waterBtn">💧 Полить</button>
                    <button class="tut-s" id="nutrBtn">🧪 Удобрения</button>
                </div>`;
            }
            
            document.getElementById('infoBody').innerHTML = html;
            document.getElementById('infoModal').classList.add('open');
            
            if (p.stage >= 6) {
                document.getElementById('harvestBtn').addEventListener('click', () => harvest(p));
            } else {
                document.getElementById('waterBtn').addEventListener('click', () => { p.water = Math.min(100, p.water + 30); showInfo(p); toast('💧', 'Полито!'); save(); });
                document.getElementById('nutrBtn').addEventListener('click', () => { document.getElementById('infoModal').classList.remove('open'); document.getElementById('nutrModal').classList.add('open'); });
            }
        }
        
        // Events
        document.addEventListener('DOMContentLoaded', () => {
            load();
            document.getElementById('start').addEventListener('click', () => { document.getElementById('tut').classList.add('h'); loop = setInterval(tick, 1000); });
            document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => { document.querySelectorAll('.tab').forEach(x => x.classList.remove('on')); t.classList.add('on'); render(t.dataset.t); }));
            document.querySelectorAll('[data-s]').forEach(b => b.addEventListener('click', () => { document.querySelectorAll('[data-s]').forEach(x => x.classList.remove('on')); b.classList.add('on'); S.speed = parseInt(b.dataset.s); }));
            document.querySelectorAll('[data-a]').forEach(b => b.addEventListener('click', () => {
                const a = b.dataset.a;
                if (a === 'plant') { if (S.selected === null) toast('❌', 'Выбери слот'); else if (S.plants.find(p => p.slot === S.selected)) toast('❌', 'Слот занят'); else document.getElementById('seedModal').classList.add('open'); }
                else if (a === 'water') { if (S.plants.length === 0) toast('💧', 'Нет растений'); else { S.plants.forEach(p => p.water = Math.min(100, p.water + 30)); toast('💧', 'Полито!'); } }
                else if (a === 'nutrient') { if (S.selected === null) toast('❌', 'Выбери растение'); else document.getElementById('nutrModal').classList.add('open'); }
                else if (a === 'harvest') { if (S.selected === null) toast('❌', 'Выбери растение'); else { const p = S.plants.find(x => x.slot === S.selected); if (!p) toast('❌', 'Пусто'); else if (p.stage < 6) toast('❌', 'Не готово'); else harvest(p); } }
                else if (a === 'save') { save(); toast('💾', 'Сохранено!'); }
            }));
            
            document.getElementById('content').addEventListener('click', e => {
                const pot = e.target.closest('.pot');
                if (pot) {
                    const i = parseInt(pot.dataset.slot);
                    S.selected = i;
                    const p = S.plants.find(x => x.slot === i);
                    if (!p) document.getElementById('seedModal').classList.add('open');
                    else showInfo(p);
                    render('grow');
                }
                
                const seed = e.target.closest('[data-seed]');
                if (seed) plantSeed(seed.dataset.seed);
                
                const nut = e.target.closest('[data-nut]');
                if (nut) buyNutrient(nut.dataset.nut);
                
                const equip = e.target.closest('[data-equip]');
                if (equip) buyEquipment(equip.dataset.equip);
                
                const lab = e.target.closest('[data-lab]');
                if (lab) buyLab(lab.dataset.lab);
                
                const lesson = e.target.closest('[data-lesson]');
                if (lesson) {
                    const id = lesson.dataset.lesson;
                    const l = lessons.find(x => x.id === id);
                    const unlocked = l && (l.unlocked || (l.id === 'training' && S.stats.harvests >= 1) || 
                                          (l.id === 'flower' && S.stats.harvests >= 2) || 
                                          (l.id === 'harvest' && S.stats.harvests >= 5) ||
                                          (l.id === 'genetics' && S.research[0].done) ||
                                          (l.id === 'pests' && S.stats.planted >= 10));
                    if (unlocked) showLesson(id);
                }
            });
            
            document.querySelectorAll('[data-c]').forEach(b => b.addEventListener('click', () => document.getElementById(b.dataset.c).classList.remove('open')));
            document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); }));
            
            render('grow');
            update();
        });
    </script>
</body>
</html>